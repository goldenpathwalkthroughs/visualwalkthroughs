# Copy this file to .env and fill in your values.
# NEVER commit .env — it is git-ignored.

# IGDB (game validation + box art)
# Obtain at: https://dev.twitch.tv/console → Applications → Create
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# YouTube Data API v3 (video verification)
# Obtain at: https://console.cloud.google.com → APIs & Services → Credentials
YOUTUBE_API_KEY=

# Cloudflare Pages (deploy/promote/rollback)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_PROJECT_NAME=visualwalkthroughs

# Pipeline settings (override pipeline.config.json values if needed)
# PIPELINE_MAX_FIX_ATTEMPTS=3
