---
import Base from '../../layouts/Base.astro';
import WorldMap from '../../components/WorldMap.astro';
import { getCollection } from 'astro:content';
import { applySequencing } from '../../lib/sequencer.js';
import { existsSync } from 'node:fs';
import { fileURLToPath } from 'node:url';

// Generic guide renderer. Renders any published game from its JSON — used by
// autonomously-built guides. Hand-written bespoke pages take precedence: any
// game that already has src/pages/<franchise>/<slug>.astro is EXCLUDED here, so
// the 12 existing guides are untouched (zero regression).
export async function getStaticPaths() {
  const srcPages = fileURLToPath(new URL('../', import.meta.url)); // → src/pages/
  const franchises = await getCollection('franchises');
  const franchiseBySlug = new Map(franchises.map((f) => [f.data.slug, f.data]));
  return (await getCollection('games'))
    .filter((g) => g.data.status === 'published')
    .filter((g) => !existsSync(`${srcPages}${g.data.franchiseSlug}/${g.data.slug}.astro`))
    .map((g) => ({
      params: { franchise: g.data.franchiseSlug, game: g.data.slug },
      props: { game: g, franchise: franchiseBySlug.get(g.data.franchiseSlug) ?? null },
    }));
}

const { game, franchise } = Astro.props as { game: any; franchise: any };
const franchiseSlug: string = game.data.franchiseSlug;
const gameSlug: string = game.data.slug;
const franchiseName: string = franchise?.name ?? franchiseSlug;

const enriched = applySequencing(game.data);
const seqRoute: Array<any> = (enriched as any)._sequencing.route;
const seqBySid = new Map(seqRoute.map((r: any) => [r.sectionId, r]));
const detourById = new Map(
  ((game.data as any).detours ?? []).map((d: any) => [d.id, d])
);

const { title, lede, platforms, theme } = game.data;
const cover = (game.data as any).cover as string | undefined;
const sections = enriched.sections;

const bossFightBySid = new Map(
  ((game.data as any).bossFights ?? []).map((b: any) => [b.sectionId, b])
);

// Ganon's Castle has two boss fights (Ganondorf + Ganon) — build a list keyed by sectionId
const bossFightListBySid = new Map<string, any[]>();
for (const b of ((game.data as any).bossFights ?? [])) {
  const arr = bossFightListBySid.get(b.sectionId) ?? [];
  arr.push(b);
  bossFightListBySid.set(b.sectionId, arr);
}

const locations: any[] = (game.data as any).locations ?? [];

// v4 action-adventure reference back-matter
const itemReference: any[] = (game.data as any).itemReference ?? [];
const songs: any[] = (game.data as any).songs ?? [];
const collectibleCategories: any[] = (game.data as any).collectibleCategories ?? [];
const sideQuestChains: any[] = (game.data as any).sideQuestChains ?? [];
const shops: any[] = (game.data as any).shops ?? [];
// v5 time-loop module
const timeCycle: any = (game.data as any).timeCycle ?? null;
const scheduledEvents: any[] = (game.data as any).scheduledEvents ?? [];
// v6 ability-driven "voices" reference (CRPG character spine)
const voices: any[] = (game.data as any).voices ?? [];
const voicesTitle: string = (game.data as any).voicesTitle ?? 'Abilities';
const voicesIntro: string = (game.data as any).voicesIntro ?? '';
const hasReference = itemReference.length > 0 || songs.length > 0 || collectibleCategories.length > 0 || sideQuestChains.length > 0 || shops.length > 0 || !!timeCycle || scheduledEvents.length > 0;

const advLabel: Record<string, string> = {
  'do-now': 'Do this now',
  upgrade: 'Permanent upgrade',
  missable: 'Missable',
  warning: 'Heads up',
  tip: 'Tip',
};
const advIcon: Record<string, string> = {
  'do-now': '★',
  upgrade: '⬆',
  missable: '⚠',
  warning: '⚠',
  tip: '💡',
};

const searchIndex = [
  {
    t: title,
    s: `${platforms.join(' / ')} · full guide`,
    k: 'game',
    ic: '🎮',
    href: `/${franchiseSlug}/${gameSlug}/`,
  },
  ...sections.map((s: any, i: number) => ({
    t: s.title,
    s: `${title} · ${s.stage}`,
    k: 'section',
    ic: '📍',
    href: `/${franchiseSlug}/${gameSlug}/`,
    sec: i,
  })),
];

const sectionsJson = JSON.stringify(sections.map((s: any, i: number) => ({
  i,
  collectCount: s.collectibles.length,
})));

function formatTs(secs: number): string {
  const m = Math.floor(secs / 60);
  const s = secs % 60;
  return `${m}:${String(s).padStart(2, '0')}`;
}

function isStepObj(step: unknown): step is { text: string; videoTimestamp?: number; spoiler?: boolean } {
  return typeof step === 'object' && step !== null && 'text' in step;
}
---

<Base
  title={title}
  description={lede}
  bodyClass={theme?.bodyClass}
  searchIndex={searchIndex}
  preloadImage={cover}
>
  <div class="oot-hero mm-hero gen-hero">
    <div class="hyrule-sky"></div>
    <div class="inner">
      <div class="crumb" style="padding-top:6px">
        <a href="/">Browse</a>
        <span>/</span>
        <a href={`/${franchiseSlug}/`}>{franchiseName}</a>
        <span>/</span>
        <span style="color:var(--text)">{title}</span>
      </div>
      <div class="ww-top">
        <div class="ww-cover">
          {cover
            ? <img src={cover} alt={`${title} box art`} class="ww-cover-img" loading="eager" decoding="async" />
            : <><div class="tri"></div><small>{title}</small></>
          }
        </div>
        <div class="ww-info">
          <div class="badges">
            <span class="b hot">Fan guide</span>
            <span class="b">{platforms.join(' / ')}</span>
            <span class="b">Golden path + boss strategies</span>
            <span class="b">Spoiler-safe</span>
          </div>
          <h1>{title}</h1>
          <p class="lede">{lede}</p>
        </div>
      </div>
      <div class="ctrls">
        <div class="progress-wrap">
          <div class="lab">
            <span>Golden-path progress</span>
            <b id="prog-txt">0 / {sections.length} sections</b>
          </div>
          <div class="bar"><i id="prog-bar"></i></div>
        </div>
        <button class="toggle on" id="spoiler-toggle" onclick="toggleSpoilers()">
          <span class="dot"></span>
          <span id="spoiler-label">Spoiler-safe: ON</span>
        </button>
        <button class="toggle" id="comp-toggle" onclick="toggleComp()">
          <span class="dot"></span>
          <span id="comp-label">Completionist: OFF</span>
        </button>
      </div>
    </div>
  </div>

  <div class="wrap">
    {voices.length > 0 && (
      <section class="voices">
        <div class="voices-head">
          <h2>{voicesTitle}</h2>
          {voicesIntro && <p>{voicesIntro}</p>}
        </div>
        <div class="voices-grid">
          {voices.map((v: any) => (
            <div class="voice-card">
              <div class="voice-top">
                <span class="voice-ab">{v.ability}</span>
                <span class="voice-name">{v.name}</span>
              </div>
              <p class="voice-theme">{v.theme}</p>
              <p class="voice-governs"><strong>Governs:</strong> {v.governs}</p>
              {v.buildNote && <p class="voice-build">{v.buildNote}</p>}
            </div>
          ))}
        </div>
      </section>
    )}

    {(game.data as any).worldMap && (
      <WorldMap
        worldMap={(game.data as any).worldMap}
        locations={locations}
        sections={sections}
      />
    )}

    {hasReference && (
      <div class="essentials">
        <div class="essentials-head">
          <h2>Guide reference</h2>
          <p>The standing reference behind the route — items, abilities, collectibles, side-quests, and the systems you'll lean on throughout {title}.</p>
        </div>

        {timeCycle && (
          <details class="ref-panel" open>
            <summary><span class="ref-ic" aria-hidden="true">⏳</span> The three-day cycle <span class="ref-sub">{timeCycle.cycleLength}</span></summary>
            <div class="ref-panel-body">
              <p class="cycle-reset"><strong>Reset:</strong> {timeCycle.resetMechanic}</p>
              <div class="cycle-cols">
                <div class="cycle-col cycle-keep">
                  <div class="cycle-col-head">You keep</div>
                  <ul>{timeCycle.persists.map((x: string) => <li>{x}</li>)}</ul>
                </div>
                <div class="cycle-col cycle-lose">
                  <div class="cycle-col-head">You lose</div>
                  <ul>{timeCycle.lost.map((x: string) => <li>{x}</li>)}</ul>
                </div>
              </div>
              {timeCycle.controls?.length > 0 && (
                <div class="cycle-controls">
                  <div class="cycle-col-head">Bend time</div>
                  {timeCycle.controls.map((c: any) => (
                    <div class="cycle-ctrl"><strong>{c.name}</strong><span>{c.effect}</span></div>
                  ))}
                </div>
              )}
              {timeCycle.note && <p class="ref-note">{timeCycle.note}</p>}
            </div>
          </details>
        )}

        {scheduledEvents.length > 0 && (
          <details class="ref-panel">
            <summary><span class="ref-ic" aria-hidden="true">📓</span> Bombers' Notebook — who, where &amp; when <span class="ref-sub">{scheduledEvents.length} timed events · masks &amp; Heart Pieces</span></summary>
            <div class="ref-panel-body">
              <div class="sched-list">
                {scheduledEvents.map((e: any) => (
                  <div class="sched-row">
                    <div class="sched-when">
                      <span class="sched-day">{e.days}</span>
                      {e.time && <span class="sched-time">{e.time}</span>}
                    </div>
                    <div class="sched-body">
                      <div class="sched-name">{e.name}{e.reward && <span class="sched-reward">{e.reward}</span>}</div>
                      <div class="sched-loc">{e.location}</div>
                      {e.prereq && <div class="sched-prereq"><span class="sched-lbl">Needs</span> {e.prereq}</div>}
                      {e.detail && <div class="sched-detail">{e.detail}</div>}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </details>
        )}

        {itemReference.length > 0 && (
          <details class="ref-panel">
            <summary><span class="ref-ic" aria-hidden="true">⚔️</span> Items &amp; equipment <span class="ref-sub">{itemReference.length} tools · where, when, what it unlocks</span></summary>
            <div class="ref-panel-body">
              <table class="ref-table">
                <tbody>
                  {itemReference.map((it: any) => (
                    <tr>
                      <td class="ir-name">{it.name}<span class="ir-cat">{it.category}</span></td>
                      <td class="ir-when">{it.when && <span class={`era era-${(it.when||'').toLowerCase()}`}>{it.when}</span>}</td>
                      <td class="ir-where">{it.where}{it.unlocks && <span class="ir-unlocks">{it.unlocks}</span>}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </details>
        )}

        {songs.length > 0 && (
          <details class="ref-panel">
            <summary><span class="ref-ic" aria-hidden="true">🎵</span> Ocarina songs <span class="ref-sub">{songs.length} songs · where learned and what they do</span></summary>
            <div class="ref-panel-body">
              {songs.map((s: any) => (
                <div class="song-row">
                  <strong class="song-name">{s.name}</strong>
                  <span class="song-where">{s.where}</span>
                  <span class="song-use">{s.use}</span>
                </div>
              ))}
            </div>
          </details>
        )}

        {collectibleCategories.map((cat: any) => (
          <details class="ref-panel">
            <summary>
              <span class="ref-ic" aria-hidden="true">✦</span> {cat.name}
              <span class="ref-sub">{cat.total ? `${cat.entries.length} listed of ${cat.total}` : `${cat.entries.length} entries`}</span>
            </summary>
            <div class="ref-panel-body">
              {cat.note && <p class="ref-note">{cat.note}</p>}
              <table class="ref-table">
                <tbody>
                  {cat.entries.map((e: any) => (
                    <tr>
                      <td class="cc-label">{e.label}</td>
                      <td class="cc-loc">{e.location}</td>
                      <td class="cc-req">
                        {e.requires && e.requires !== '—' && <span class="req-tag">{e.requires}</span>}
                        {e.era && <span class={`era era-${(e.era||'').toLowerCase()}`}>{e.era}</span>}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </details>
        ))}

        {sideQuestChains.map((q: any) => (
          <details class="ref-panel">
            <summary><span class="ref-ic" aria-hidden="true">🔗</span> {q.name} <span class="ref-sub">{q.steps.length}-step chain → {q.reward.split('—')[0].trim()}</span></summary>
            <div class="ref-panel-body">
              <p class="ref-note"><strong>Reward:</strong> {q.reward}{q.era ? ` · ${q.era} Link` : ''}</p>
              <ol class="chain-list">
                {q.steps.map((st: any) => (
                  <li>
                    <strong>{st.label}</strong>
                    {st.requires && <span class="chain-req">{st.requires}</span>}
                    {st.detail && <span class="chain-detail">{st.detail}</span>}
                  </li>
                ))}
              </ol>
            </div>
          </details>
        ))}

        {shops.length > 0 && (
          <details class="ref-panel">
            <summary><span class="ref-ic" aria-hidden="true">🛒</span> Shops <span class="ref-sub">{shops.length} shops · stock and prices</span></summary>
            <div class="ref-panel-body">
              <div class="shop-grid">
                {shops.map((sh: any) => (
                  <div class="shop-card">
                    <div class="shop-name">{sh.name}<span class="shop-where">{sh.where}</span></div>
                    <table class="shop-mini">
                      <tbody>
                        {sh.items.map((it: any) => (
                          <tr><td>{it.item}</td><td class="shop-price">{it.price}</td></tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                ))}
              </div>
            </div>
          </details>
        )}
      </div>
    )}

    <div class="sections">
      <div class="path-label">The journey · {sections.length} {sections.length === 1 ? 'chapter' : 'chapters'}</div>

      {sections.map((sec: any, i: number) => {
        const sid: string = sec.sectionId ?? String(sec.order);
        const seqEntry = seqBySid.get(sid);
        const gateWarnings: any[] = seqEntry?.gateWarnings ?? [];
        const readinessNote: string | null = seqEntry?.readinessNote ?? null;
        const recommendedDetourIds: string[] = sec.recommendedDetours ?? [];
        const bossFights: any[] = bossFightListBySid.get(sid) ?? [];

        return (
          <div class="sec" id={`sec-${i}`}>
            <div class="sec-head" onclick={`toggleSec(${i})`}>
              <div class="num">{i + 1}</div>
              <button
                class="check"
                title="Mark section complete"
                onclick={`event.stopPropagation();markDone(${i})`}
                aria-label={`Mark "${sec.title}" complete`}
              >✓</button>
              <div class="htext">
                <div class="stage">{sec.stage}</div>
                <h2>{sec.title}</h2>
                <div class="chips">
                  {sec.chips.map((c: string) => <span class="chip">{c}</span>)}
                </div>
              </div>
              <div class="chev" aria-hidden="true">▾</div>
            </div>

            <div class="sec-body">
              <div class="inner">
                <div class="sec-content">
                  <!-- Left: prose -->
                  <div class="prose" id={`prose-${i}`}>
                    <button class="tts" onclick={`speak(${i},event)`} aria-label="Listen to this section">▶ Listen to this section</button>

                    {gateWarnings.filter((w: any) => w.gatingType === 'hard').map((w: any) => (
                      <div class="gate-card gate-hard">
                        <span class="gate-ico" aria-hidden="true">⛔</span>
                        <div class="gate-body">
                          <span class="gate-type">Required to proceed</span>
                          You need <strong>{w.name}</strong> to continue from here.
                        </div>
                      </div>
                    ))}

                    {readinessNote && (
                      <div class="gate-card gate-soft">
                        <span class="gate-ico" aria-hidden="true">👆</span>
                        <div class="gate-body">
                          <span class="gate-type">Recommended first</span>
                          {readinessNote}
                        </div>
                      </div>
                    )}

                    {(sec.objectives ?? []).length > 0 && (
                      <div class="objectives">
                        <div class="objectives-label">Objectives</div>
                        <ol class="objectives-list">
                          {sec.objectives.map((o: any) => (
                            <li class={o.optional ? 'obj-optional' : ''}>{o.label}{o.optional && <span class="obj-opt-tag">optional</span>}</li>
                          ))}
                        </ol>
                      </div>
                    )}

                    <h3>Golden path</h3>
                    <ol>
                      {sec.steps.map((step: unknown) => (
                        <li class={isStepObj(step) && (step as any).spoiler ? 'spoiler-li' : ''}>
                          {isStepObj(step) ? (
                            <>
                              <span set:html={step.text} />
                              {(step as any).locationRef && (
                                <span class="loc-ref" title={`Map ref: ${(step as any).locationRef}`} aria-label={`Map: ${(step as any).locationRef}`}>{(step as any).locationRef}</span>
                              )}
                              {step.videoTimestamp !== undefined && (
                                <button
                                  class="ts-btn"
                                  onclick={`seekVid(${i},${step.videoTimestamp})`}
                                  title={`Jump video to ${formatTs(step.videoTimestamp)}`}
                                  aria-label={`Watch from ${formatTs(step.videoTimestamp)}`}
                                >▶ {formatTs(step.videoTimestamp)}</button>
                              )}
                            </>
                          ) : (
                            <Fragment set:html={step as string} />
                          )}
                        </li>
                      ))}
                    </ol>

                    {sec.dungeonMap?.floors?.length > 0 && (
                      <details class="dmap">
                        <summary><span class="dmap-ic" aria-hidden="true">🗺️</span> Dungeon map — keyed contents <span class="dmap-sub">{sec.dungeonMap.floors.length} floors</span></summary>
                        <div class="dmap-body">
                          {sec.dungeonMap.floors.map((fl: any) => (
                            <div class="dmap-floor">
                              <div class="dmap-floor-label">{fl.label}</div>
                              <ul class="dmap-markers">
                                {fl.markers.map((m: any) => (
                                  <li class={`dmark dmark-${m.kind}`}>
                                    <span class="dmark-key">{m.key}</span>
                                    <span class="dmark-kind">{m.kind.replace('-', ' ')}</span>
                                    <span class="dmark-label">{m.label}</span>
                                  </li>
                                ))}
                              </ul>
                            </div>
                          ))}
                        </div>
                      </details>
                    )}

                    {(sec.rooms ?? []).length > 0 && (
                      <details class="rooms">
                        <summary><span class="dmap-ic" aria-hidden="true">🧩</span> Room-by-room &amp; puzzle solutions <span class="dmap-sub">{sec.rooms.length} rooms</span></summary>
                        <div class="rooms-body">
                          {sec.rooms.map((rm: any) => (
                            <div class="room-card">
                              <div class="room-name">{rm.name}</div>
                              <p class="room-solution"><span class="room-sol-tag">Solve</span> {rm.solution}</p>
                              {rm.enemies && <div class="room-meta"><span class="room-meta-lbl">Enemies</span> {rm.enemies}</div>}
                              {rm.treasure && <div class="room-meta"><span class="room-meta-lbl room-treasure">Treasure</span> {rm.treasure}</div>}
                            </div>
                          ))}
                        </div>
                      </details>
                    )}

                    {sec.advisories.filter((a: any) => !a.completionistOnly).map((a: any) => (
                      <div class="adv" data-t={a.type}>
                        <span class="ico" aria-hidden="true">{advIcon[a.type]}</span>
                        <span class="at">{advLabel[a.type]}</span>
                        <strong>{a.title}.</strong> <span set:html={a.body} />
                      </div>
                    ))}

                    {sec.advisories.filter((a: any) => a.completionistOnly).map((a: any) => (
                      <div class="adv comp-only" data-t={a.type}>
                        <span class="ico" aria-hidden="true">{advIcon[a.type]}</span>
                        <span class="at">{advLabel[a.type]}</span>
                        <strong>{a.title}.</strong> <span set:html={a.body} />
                      </div>
                    ))}

                    {/* Boss fight block(s) — OoT Ganon's Castle has two consecutive fights */}
                    {bossFights.map((bossFight: any) => (
                      <div class="boss-block">
                        <div class="boss-head">
                          <span class="boss-badge">Boss</span>
                          <strong class="boss-name">{bossFight.name}</strong>
                          {bossFight.locationRef && (
                            <span class="boss-loc">{bossFight.locationRef}</span>
                          )}
                        </div>

                        <div class="boss-prep">
                          <div class="boss-section-label">Preparation</div>
                          <p class="boss-prep-text">{bossFight.prep.healthAdvice}</p>
                          {bossFight.prep.topUpBefore && (
                            <p class="boss-prep-topup">
                              <strong>Top up before:</strong> {bossFight.prep.topUpBefore}
                            </p>
                          )}
                        </div>

                        <div class="boss-phases">
                          <div class="boss-section-label">Fight breakdown</div>
                          {bossFight.phases.map((phase: any) => (
                            <div class="boss-phase">
                              <div class="phase-name">{phase.name}</div>
                              {phase.tells && <div class="phase-row"><span class="phase-lbl">Tell</span><span class="phase-val">{phase.tells}</span></div>}
                              {phase.counter && <div class="phase-row"><span class="phase-lbl">Counter</span><span class="phase-val">{phase.counter}</span></div>}
                              {phase.damageWindow && <div class="phase-row"><span class="phase-lbl">Damage window</span><span class="phase-val">{phase.damageWindow}</span></div>}
                              {phase.summary && <div class="phase-row"><span class="phase-lbl">Summary</span><span class="phase-val">{phase.summary}</span></div>}
                            </div>
                          ))}
                        </div>

                        <div class="boss-struggle">
                          <div class="boss-section-label">If you're struggling</div>
                          <p><strong>Where to heal:</strong> {bossFight.ifYouStruggle.whereToHeal}</p>
                          <p><strong>Easier tactic:</strong> {bossFight.ifYouStruggle.easierTactic}</p>
                          {bossFight.ifYouStruggle.retreatOption && (
                            <p><strong>Retreat:</strong> {bossFight.ifYouStruggle.retreatOption}</p>
                          )}
                        </div>

                        <div class="boss-reward">
                          <span class="boss-reward-lbl">Reward:</span> {bossFight.reward}
                        </div>
                      </div>
                    ))}

                    {recommendedDetourIds.length > 0 && (
                      <div class="detour-group">
                        <div class="detour-group-head">Optional · strengthen your character</div>
                        {recommendedDetourIds.map((dId: string) => {
                          const d = detourById.get(dId);
                          if (!d) return null;
                          return (
                            <div class={`detour-card detour-${(d as any).type}`}>
                              <div class="detour-head">
                                <span class="opt-badge">Optional</span>
                                <strong class="detour-loc">{(d as any).location}</strong>
                                <span class="detour-benefit">{(d as any).benefit}</span>
                              </div>
                              <p class="detour-method">{(d as any).method}</p>
                            </div>
                          );
                        })}
                      </div>
                    )}

                    {sec.collectibles.length > 0 && (
                      <div class="comp-block comp-only">
                        <h3>Completionist · this area</h3>
                        <div class="cc" id={`cc-${i}`}>0 / {sec.collectibles.length} collected</div>
                        {sec.collectibles.map((c: any, j: number) => (
                          <div class="coll" id={`coll-${i}-${j}`} onclick={`toggleColl(${i},${j})`} role="checkbox" aria-checked="false" tabindex="0">
                            <div class="box" aria-hidden="true">✓</div>
                            <div class="ct">
                              <b>{c.label}</b>
                              <span>{c.note}</span>
                            </div>
                          </div>
                        ))}
                      </div>
                    )}
                  </div>

                  <!-- Right: video -->
                  {sec.video?.id && (
                  <div class="aside">
                    <h3>Watch it instead</h3>
                    <div class="vid" id={`vid-${i}`} data-id={sec.video.id}>
                      <div
                        class="thumb"
                        onclick="playVid(this)"
                        style={`background-image:url(https://i.ytimg.com/vi/${sec.video.id}/hqdefault.jpg)`}
                        role="button"
                        aria-label={`Play: ${sec.video.title}`}
                        tabindex="0"
                      >
                        <span class="dur">{sec.video.durationLabel}</span>
                        <div class="play" aria-hidden="true">
                          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M8 5v14l11-7z"/>
                          </svg>
                        </div>
                      </div>
                      <div class="vmeta">
                        <div class="creator">▶ {sec.video.creator}</div>
                        <div class="vt">{sec.video.title}</div>
                      </div>
                    </div>
                    <p class="lazy-note">▲ thumbnail from YouTube's CDN · the player loads only when you press play</p>
                  </div>
                  )}
                </div>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</Base>

