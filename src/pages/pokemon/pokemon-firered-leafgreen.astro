---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { applySequencing } from '../../lib/sequencer.js';

const game = (await getCollection('games')).find(g => g.data.slug === 'pokemon-firered-leafgreen');
if (!game) throw new Error('Game not found');

const enriched = applySequencing(game.data);
const seqRoute: Array<any> = (enriched as any)._sequencing.route;
const seqBySid = new Map(seqRoute.map((r: any) => [r.sectionId, r]));

const { title, lede, platforms, theme } = game.data;
const cover = (game.data as any).cover as string | undefined;
const sections = enriched.sections;

// v3 reference pillars
const mechanics = (game.data as any).mechanicsReference;
const tmhm = (game.data as any).moveItemIndex;
const creatures: any[] = (game.data as any).creatures ?? [];

const rarityLabel: Record<string, string> = {
  'very-common': 'Very common', common: 'Common', uncommon: 'Uncommon',
  rare: 'Rare', 'very-rare': 'Very rare', 'one-time': 'One-time',
};
const methodLabel: Record<string, string> = {
  grass: 'Tall grass', surf: 'Surfing', 'old-rod': 'Old Rod', 'good-rod': 'Good Rod',
  'super-rod': 'Super Rod', 'rock-smash': 'Rock Smash', gift: 'Gift', static: 'Static',
  fishing: 'Fishing', fossil: 'Fossil', 'game-corner': 'Game Corner', other: 'Special',
};
function verTag(v: string | undefined): { txt: string; cls: string } | null {
  if (v === 'firered') return { txt: 'FireRed', cls: 'ver-fr' };
  if (v === 'leafgreen') return { txt: 'LeafGreen', cls: 'ver-lg' };
  return null;
}

const advLabel: Record<string, string> = {
  'do-now': 'Do this now',
  upgrade: 'Permanent upgrade',
  missable: 'Missable',
  warning: 'Heads up',
  tip: 'Tip',
};
const advIcon: Record<string, string> = {
  'do-now': '★',
  upgrade: '⬆',
  missable: '⚠',
  warning: '⚠',
  tip: '💡',
};

const searchIndex = [
  {
    t: title,
    s: `${platforms.join(' / ')} · full guide`,
    k: 'game',
    ic: '🔴',
    href: `/pokemon/pokemon-firered-leafgreen/`,
  },
  ...sections.map((s: any, i: number) => ({
    t: s.title,
    s: `Pokémon FireRed & LeafGreen · ${s.stage}`,
    k: 'section',
    ic: '📍',
    href: `/pokemon/pokemon-firered-leafgreen/`,
    sec: i,
  })),
];

const sectionsJson = JSON.stringify(sections.map((s: any) => ({
  collectCount: s.collectibles.length,
})));

function isStepObj(step: unknown): step is { id?: string; text: string; spoiler?: boolean; bossRef?: string } {
  return typeof step === 'object' && step !== null && 'text' in step;
}
---

<Base
  title={title}
  description={lede}
  bodyClass={theme?.bodyClass}
  searchIndex={searchIndex}
>
  <div class="pokemon-hero">
    <div class="pokemon-bg"></div>
    <div class="inner">
      <div class="crumb" style="padding-top:6px">
        <a href="/">Browse</a>
        <span>/</span>
        <a href="/pokemon/">Pokémon</a>
        <span>/</span>
        <span style="color:var(--text)">{title}</span>
      </div>
      <div class="hero-top">
        <div class="hero-cover">
          {cover
            ? <img src={cover} alt={`${title} cover art`} class="hero-cover-img" loading="eager" decoding="async" />
            : <div class="hero-cover-placeholder"><span>🔴</span><small>FIRERED / LEAFGREEN</small></div>
          }
        </div>
        <div class="hero-info">
          <div class="badges">
            <span class="b hot">Fan guide</span>
            <span class="b">{platforms.join(' / ')}</span>
            <span class="b">Golden path + Gyms</span>
            <span class="b">Spoiler-safe</span>
          </div>
          <h1>{title}</h1>
          <p class="lede">{lede}</p>
        </div>
      </div>
      <div class="ctrls">
        <div class="progress-wrap">
          <div class="lab">
            <span>Golden-path progress</span>
            <b id="prog-txt">0 / {sections.length} sections</b>
          </div>
          <div class="bar"><i id="prog-bar"></i></div>
        </div>
        <button class="toggle on" id="spoiler-toggle" onclick="toggleSpoilers()">
          <span class="dot"></span>
          <span id="spoiler-label">Spoiler-safe: ON</span>
        </button>
        <button class="toggle" id="comp-toggle" onclick="toggleComp()">
          <span class="dot"></span>
          <span id="comp-label">Completionist: OFF</span>
        </button>
      </div>
    </div>
  </div>

  <div class="wrap">
    {(mechanics || tmhm || creatures.length > 0) && (
      <div class="essentials">
        <div class="essentials-head">
          <h2>Game Essentials &amp; Reference</h2>
          <p>The standing reference behind the walkthrough — type matchups, status, evolution, every TM and HM, and the team-defining Pokémon and where to catch them.</p>
        </div>

        {mechanics?.typeChart?.length > 0 && (
          <details class="ref-panel">
            <summary><span class="ref-ic" aria-hidden="true">⚔️</span> Type matchup chart <span class="ref-sub">how much damage each attack type deals</span></summary>
            <div class="ref-panel-body">
              <div class="type-grid">
                {mechanics.typeChart.map((row: any) => (
                  <div class="type-row">
                    <span class={`tcell type-${row.type.toLowerCase()}`}>{row.type}</span>
                    <div class="type-eff">
                      {row.strongVs.length > 0 && <div class="te te-strong"><b>2× vs</b> {row.strongVs.join(', ')}</div>}
                      {row.weakVs.length > 0 && <div class="te te-weak"><b>½× vs</b> {row.weakVs.join(', ')}</div>}
                      {row.noEffectVs.length > 0 && <div class="te te-none"><b>0× vs</b> {row.noEffectVs.join(', ')}</div>}
                    </div>
                  </div>
                ))}
              </div>
              {mechanics.notes?.length > 0 && (
                <ul class="ref-notes">
                  {mechanics.notes.map((n: string) => <li>{n}</li>)}
                </ul>
              )}
            </div>
          </details>
        )}

        {mechanics?.statusConditions?.length > 0 && (
          <details class="ref-panel">
            <summary><span class="ref-ic" aria-hidden="true">🌀</span> Status conditions <span class="ref-sub">what each does and how to cure it</span></summary>
            <div class="ref-panel-body">
              {mechanics.statusConditions.map((s: any) => (
                <div class="status-row">
                  <strong class="status-name">{s.name}</strong>
                  <span class="status-effect">{s.effect}</span>
                  {s.cure && <span class="status-cure"><b>Cure:</b> {s.cure}</span>}
                </div>
              ))}
            </div>
          </details>
        )}

        {mechanics?.evolutionMethods?.length > 0 && (
          <details class="ref-panel">
            <summary><span class="ref-ic" aria-hidden="true">✨</span> Evolution methods <span class="ref-sub">level, stone, trade, item, friendship</span></summary>
            <div class="ref-panel-body">
              {mechanics.evolutionMethods.map((e: any) => (
                <div class="evo-row">
                  <strong class="evo-method">{e.method}</strong>
                  <span class="evo-detail">{e.detail}</span>
                  {e.examples && <span class="evo-examples">e.g. {e.examples}</span>}
                </div>
              ))}
            </div>
          </details>
        )}

        {(tmhm?.tms?.length > 0 || tmhm?.hms?.length > 0) && (
          <details class="ref-panel">
            <summary><span class="ref-ic" aria-hidden="true">💿</span> TM &amp; HM index <span class="ref-sub">{(tmhm.tms?.length ?? 0)} TMs · {(tmhm.hms?.length ?? 0)} HMs · where to find each</span></summary>
            <div class="ref-panel-body">
              {tmhm.hms?.length > 0 && (
                <>
                  <div class="ref-block-label">HMs (field moves)</div>
                  <table class="tm-table">
                    <tbody>
                      {tmhm.hms.map((h: any) => (
                        <tr>
                          <td class="tm-id">{h.id}</td>
                          <td class="tm-move">{h.move}{h.typeLabel && <span class={`type-pill type-${h.typeLabel.toLowerCase()}`}>{h.typeLabel}</span>}</td>
                          <td class="tm-loc">{h.location}{h.notes ? ` — ${h.notes}` : ''}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </>
              )}
              <div class="ref-block-label">TMs</div>
              <table class="tm-table">
                <tbody>
                  {tmhm.tms.map((t: any) => (
                    <tr>
                      <td class="tm-id">{t.id}</td>
                      <td class="tm-move">{t.move}{t.typeLabel && <span class={`type-pill type-${t.typeLabel.toLowerCase()}`}>{t.typeLabel}</span>}</td>
                      <td class="tm-loc">{t.location}{t.notes ? ` — ${t.notes}` : ''}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </details>
        )}

        {creatures.length > 0 && (
          <details class="ref-panel">
            <summary><span class="ref-ic" aria-hidden="true">📕</span> Pokédex — team-defining catches <span class="ref-sub">{creatures.length} key Pokémon · where, how, and why</span></summary>
            <div class="ref-panel-body">
              <div class="creature-grid">
                {creatures.map((c: any) => (
                  <div class="creature-card">
                    <div class="creature-head">
                      {c.dexNo && <span class="creature-no">#{String(c.dexNo).padStart(3, '0')}</span>}
                      <strong class="creature-name">{c.name}</strong>
                      <span class="creature-types">
                        {c.types.map((t: string) => <span class={`type-pill type-${t.toLowerCase()}`}>{t}</span>)}
                      </span>
                    </div>
                    {c.role && <p class="creature-role">{c.role}</p>}
                    {c.catchLocations?.length > 0 && (
                      <div class="creature-line">
                        <span class="cl-label">Catch</span>
                        <span>
                          {c.catchLocations.map((cl: any) => {
                            const vt = verTag(cl.versionExclusive);
                            return (
                              <span class="catch-loc">
                                {cl.where} <em>({methodLabel[cl.method] ?? cl.method}{cl.levelRange ? `, ${cl.levelRange}` : ''})</em>
                                {vt && <span class={`ver ${vt.cls}`}>{vt.txt}</span>}
                              </span>
                            );
                          })}
                        </span>
                      </div>
                    )}
                    {c.evolution && (
                      <div class="creature-line"><span class="cl-label">Evolves</span><span>{c.evolution}</span></div>
                    )}
                    {c.notableMoves?.length > 0 && (
                      <div class="creature-line">
                        <span class="cl-label">Key moves</span>
                        <span class="move-tags">
                          {c.notableMoves.map((m: any) => <span class="move-tag">{m.move} <em>{m.level}</em></span>)}
                        </span>
                      </div>
                    )}
                  </div>
                ))}
              </div>
            </div>
          </details>
        )}
      </div>
    )}

    <div class="sections">
      <div class="path-label">Golden path · Earn all eight Gym Badges</div>

      {sections.map((sec: any, i: number) => {
        const sid: string = sec.sectionId ?? String(sec.order);
        const seqEntry = seqBySid.get(sid);
        const gateWarnings: any[] = seqEntry?.gateWarnings ?? [];
        const readinessNote: string | null = seqEntry?.readinessNote ?? null;
        const allBossFights: any[] = ((game.data as any).bossFights ?? []).filter((b: any) => b.sectionId === sid);

        return (
          <div class="sec" id={`sec-${i}`}>
            <div class="sec-head" onclick={`toggleSec(${i})`}>
              <div class="num">{i + 1}</div>
              <button
                class="check"
                title="Mark section complete"
                onclick={`event.stopPropagation();markDone(${i})`}
                aria-label={`Mark "${sec.title}" complete`}
              >✓</button>
              <div class="htext">
                <div class="stage">{sec.stage}</div>
                <h2>{sec.title}</h2>
                <div class="chips">
                  {sec.chips.map((c: string) => <span class="chip">{c}</span>)}
                </div>
              </div>
              <div class="chev" aria-hidden="true">▾</div>
            </div>

            <div class="sec-body">
              <div class="inner">
                <div class="sec-content">
                  <div class="prose" id={`prose-${i}`}>
                    <button class="tts" onclick={`speak(${i},event)`} aria-label="Listen to this section">▶ Listen to this section</button>

                    {gateWarnings.filter((w: any) => w.gatingType === 'hard').map((w: any) => (
                      <div class="gate-card gate-hard">
                        <span class="gate-ico" aria-hidden="true">⛔</span>
                        <div class="gate-body">
                          <span class="gate-type">Required to proceed</span>
                          You need <strong>{w.name}</strong> to continue from here.
                        </div>
                      </div>
                    ))}

                    {readinessNote && (
                      <div class="gate-card gate-soft">
                        <span class="gate-ico" aria-hidden="true">👆</span>
                        <div class="gate-body">
                          <span class="gate-type">Recommended first</span>
                          {readinessNote}
                        </div>
                      </div>
                    )}

                    <h3>Golden path</h3>
                    <ol>
                      {sec.steps.map((step: unknown) => {
                        if (!isStepObj(step)) {
                          return <li><Fragment set:html={step as string} /></li>;
                        }
                        return (
                          <li class={step.spoiler ? 'spoiler' : ''}>
                            {step.spoiler
                              ? <><span class="spoiler-label" aria-hidden="true">Spoiler — tap to reveal</span><span set:html={step.text} /></>
                              : <span set:html={step.text} />
                            }
                          </li>
                        );
                      })}
                    </ol>

                    {sec.advisories.filter((a: any) => !a.completionistOnly).map((a: any) => (
                      <div class="adv" data-t={a.type}>
                        <span class="ico" aria-hidden="true">{advIcon[a.type]}</span>
                        <span class="at">{advLabel[a.type]}</span>
                        <span set:html={a.body} />
                      </div>
                    ))}

                    {sec.advisories.filter((a: any) => a.completionistOnly).map((a: any) => (
                      <div class="adv comp-only" data-t={a.type}>
                        <span class="ico" aria-hidden="true">{advIcon[a.type]}</span>
                        <span class="at">{advLabel[a.type]}</span>
                        <span set:html={a.body} />
                      </div>
                    ))}

                    {allBossFights.map((bossFight: any) => (
                      <div class="boss-block">
                        <div class="boss-head">
                          <span class="boss-badge">Gym Leader</span>
                          <strong class="boss-name">{bossFight.name}</strong>
                          {bossFight.locationRef && (
                            <span class="boss-loc">{bossFight.locationRef}</span>
                          )}
                        </div>

                        <div class="boss-prep">
                          <div class="boss-section-label">Preparation</div>
                          <p class="boss-prep-text">{bossFight.prep.healthAdvice}</p>
                          {bossFight.prep.topUpBefore && (
                            <p class="boss-prep-topup">
                              <strong>Top up before:</strong> {bossFight.prep.topUpBefore}
                            </p>
                          )}
                        </div>

                        <div class="boss-phases">
                          <div class="boss-section-label">Their team</div>
                          {bossFight.phases.map((phase: any) => (
                            <div class="boss-phase">
                              <div class="phase-name">{phase.name}</div>
                              <div class="phase-summary">{phase.summary}</div>
                            </div>
                          ))}
                        </div>

                        <div class="boss-struggle">
                          <div class="boss-section-label">If you're struggling</div>
                          <p><strong>Where to heal:</strong> {bossFight.ifYouStruggle.whereToHeal}</p>
                          <p><strong>Easier tactic:</strong> {bossFight.ifYouStruggle.easierTactic}</p>
                          {bossFight.ifYouStruggle.retreatOption && (
                            <p><strong>Retreat:</strong> {bossFight.ifYouStruggle.retreatOption}</p>
                          )}
                        </div>

                        <div class="boss-reward">
                          <span class="boss-reward-lbl">Reward:</span> {bossFight.reward}
                        </div>
                      </div>
                    ))}

                    {(sec.areas ?? []).length > 0 && (
                      <div class="area-ref">
                        <details>
                          <summary>
                            <span class="area-ref-title">Area-by-area reference</span>
                            <span class="area-ref-count">{sec.areas.length} areas · encounters, trainers, items</span>
                          </summary>
                          <div class="area-ref-body">
                            {sec.areas.map((area: any) => (
                              <div class="area-card">
                                <div class="area-head">
                                  <span class={`area-kind area-kind-${area.kind}`}>{area.kind}</span>
                                  <strong class="area-name">{area.name}</strong>
                                </div>
                                {area.summary && <p class="area-summary">{area.summary}</p>}

                                {(area.encounters ?? []).length > 0 && (
                                  <div class="area-block">
                                    <div class="area-block-label">Wild Pokémon</div>
                                    <table class="enc-table">
                                      <tbody>
                                        {area.encounters.map((e: any) => {
                                          const vt = verTag(e.versionExclusive);
                                          return (
                                            <tr>
                                              <td class="enc-species">
                                                {e.species}
                                                {vt && <span class={`ver ${vt.cls}`}>{vt.txt}</span>}
                                              </td>
                                              <td class="enc-method">{methodLabel[e.method] ?? e.method}</td>
                                              <td class="enc-rarity"><span class={`rar rar-${e.rarity}`}>{rarityLabel[e.rarity] ?? e.rarity}</span></td>
                                              <td class="enc-level">{e.levelRange ?? ''}</td>
                                            </tr>
                                          );
                                        })}
                                      </tbody>
                                    </table>
                                  </div>
                                )}

                                {(area.trainers ?? []).length > 0 && (
                                  <div class="area-block">
                                    <div class="area-block-label">Trainers</div>
                                    <ul class="trainer-list">
                                      {area.trainers.map((t: any) => (
                                        <li>
                                          <span class="trainer-name">{t.trainer}</span>
                                          <span class="trainer-team">{t.team}</span>
                                          {t.note && <span class="trainer-note">{t.note}</span>}
                                        </li>
                                      ))}
                                    </ul>
                                  </div>
                                )}

                                {(area.items ?? []).length > 0 && (
                                  <div class="area-block">
                                    <div class="area-block-label">Items</div>
                                    <ul class="item-list">
                                      {area.items.map((it: any) => (
                                        <li class={it.hidden ? 'is-hidden' : ''}>
                                          {it.hidden && <span class="hidden-tag">Hidden</span>}
                                          <span set:html={it.label} />
                                        </li>
                                      ))}
                                    </ul>
                                  </div>
                                )}

                                {(area.shop ?? []).length > 0 && (
                                  <div class="area-block">
                                    <div class="area-block-label">Poké Mart</div>
                                    <table class="shop-table">
                                      <tbody>
                                        {area.shop.map((s: any) => (
                                          <tr><td>{s.item}</td><td class="shop-price">{s.price}</td></tr>
                                        ))}
                                      </tbody>
                                    </table>
                                  </div>
                                )}

                                {(area.events ?? []).length > 0 && (
                                  <div class="area-block">
                                    <div class="area-block-label">Events</div>
                                    <ul class="event-list">
                                      {area.events.map((ev: any) => (
                                        <li class={ev.spoiler ? 'spoiler' : ''}>
                                          {ev.spoiler
                                            ? <><span class="spoiler-label" aria-hidden="true">Spoiler — tap to reveal</span><span><strong>{ev.label}.</strong> {ev.detail ?? ''}</span></>
                                            : <span><strong>{ev.label}.</strong> {ev.detail ?? ''}</span>}
                                        </li>
                                      ))}
                                    </ul>
                                  </div>
                                )}

                                {(area.backtrack ?? []).length > 0 && (
                                  <div class="area-block">
                                    <div class="area-block-label">Come back later</div>
                                    <ul class="backtrack-list">
                                      {area.backtrack.map((b: any) => (
                                        <li>
                                          <span class="bt-needs">{b.needs}</span>
                                          <span class="bt-what">{b.what}{b.reward ? ` → ${b.reward}` : ''}</span>
                                        </li>
                                      ))}
                                    </ul>
                                  </div>
                                )}
                              </div>
                            ))}
                          </div>
                        </details>
                      </div>
                    )}

                    {sec.collectibles.length > 0 && (
                      <div class="comp-block comp-only">
                        <h3>Completionist · this area</h3>
                        <div class="cc" id={`cc-${i}`}>0 / {sec.collectibles.length} collected</div>
                        {sec.collectibles.map((c: any, j: number) => (
                          <div class="coll" id={`coll-${i}-${j}`} onclick={`toggleColl(${i},${j})`} role="checkbox" aria-checked="false" tabindex="0">
                            <div class="box" aria-hidden="true">✓</div>
                            <div class="ct">
                              <b>{c.label}</b>
                              <span>{c.note}</span>
                            </div>
                          </div>
                        ))}
                      </div>
                    )}
                  </div>

                  <div class="aside">
                    <h3>Watch it instead</h3>
                    <div class="vid" id={`vid-${i}`} data-id={sec.video.id} data-start={sec.video.startSeconds ?? 0}>
                      <div
                        class="thumb"
                        onclick="playVid(this)"
                        style={`background-image:url(https://i.ytimg.com/vi/${sec.video.id}/hqdefault.jpg)`}
                        role="button"
                        aria-label={`Play: ${sec.video.title}`}
                        tabindex="0"
                      >
                        <span class="dur">{sec.video.durationLabel}</span>
                        <div class="play" aria-hidden="true">
                          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M8 5v14l11-7z"/>
                          </svg>
                        </div>
                      </div>
                      <div class="vmeta">
                        <div class="creator">▶ {sec.video.creator}</div>
                        <div class="vt">{sec.video.title}</div>
                      </div>
                    </div>
                    <p class="lazy-note">▲ thumbnail from YouTube's CDN · the player loads only when you press play</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</Base>

<style>
/* ── Pokémon FireRed hero ─────────────────────────────────────────────────── */
.pokemon-hero {
  position: relative;
  overflow: hidden;
  padding-bottom: 2.5rem;
  background: linear-gradient(160deg, #120300 0%, #0a0100 55%, #060100 100%);
}

.pokemon-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 80% 60% at 70% -10%, rgba(232,50,10,.10) 0%, transparent 60%),
    radial-gradient(ellipse 40% 40% at 15% 110%, rgba(180,20,0,.15) 0%, transparent 55%);
  pointer-events: none;
}

.pokemon-hero .inner {
  position: relative;
  max-width: 1100px;
  margin: 0 auto;
  padding: 1.5rem 1.5rem 0;
}

.hero-top {
  display: flex;
  gap: 2rem;
  align-items: flex-start;
  margin-top: 1.25rem;
}

.hero-cover {
  flex-shrink: 0;
  width: 120px;
  height: 160px;
  border-radius: 8px;
  overflow: hidden;
