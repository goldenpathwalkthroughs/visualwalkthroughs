---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { applySequencing } from '../../lib/sequencer.js';

const game = (await getCollection('games')).find(g => g.data.slug === 'pokemon-pokopia');
if (!game) throw new Error('Game not found');

const enriched = applySequencing(game.data);
const seqRoute: Array<any> = (enriched as any)._sequencing.route;
const seqBySid = new Map(seqRoute.map((r: any) => [r.sectionId, r]));
const detourById = new Map(
  ((game.data as any).detours ?? []).map((d: any) => [d.id, d])
);

const { title, lede, platforms, theme } = game.data;
const cover = (game.data as any).cover as string | undefined;
const sections = enriched.sections;

const advLabel: Record<string, string> = {
  'do-now': 'Do this now',
  upgrade: 'Permanent upgrade',
  missable: 'Missable',
  warning: 'Heads up',
  tip: 'Tip',
};
const advIcon: Record<string, string> = {
  'do-now': '★',
  upgrade: '⬆',
  missable: '⚠',
  warning: '⚠',
  tip: '💡',
};

const searchIndex = [
  {
    t: title,
    s: `${platforms.join(' / ')} · full guide`,
    k: 'game',
    ic: '🌿',
    href: `/pokemon/pokemon-pokopia/`,
  },
  ...sections.map((s: any, i: number) => ({
    t: s.title,
    s: `Pokémon Pokopia · ${s.stage}`,
    k: 'section',
    ic: '📍',
    href: `/pokemon/pokemon-pokopia/`,
    sec: i,
  })),
];

const sectionsJson = JSON.stringify(sections.map((s: any, i: number) => ({
  i,
  collectCount: s.collectibles.length,
})));

function formatTs(secs: number): string {
  const m = Math.floor(secs / 60);
  const s = secs % 60;
  return `${m}:${String(s).padStart(2, '0')}`;
}

function isStepObj(step: unknown): step is { text: string; videoTimestamp?: number } {
  return typeof step === 'object' && step !== null && 'text' in step;
}
---

<Base
  title={title}
  description={lede}
  bodyClass={theme?.bodyClass}
  searchIndex={searchIndex}
>
  <div class="pokopia-hero">
    <div class="pokopia-bg"></div>
    <div class="inner">
      <div class="crumb" style="padding-top:6px">
        <a href="/">Browse</a>
        <span>/</span>
        <a href="/pokemon/">Pokémon</a>
        <span>/</span>
        <span style="color:var(--text)">{title}</span>
      </div>
      <div class="pokopia-top">
        <div class="pokopia-cover">
          {cover
            ? <img src={cover} alt={`${title} cover art`} class="pokopia-cover-img" loading="eager" decoding="async" />
            : <div class="pokopia-cover-placeholder"><span class="pokopia-icon">🌿</span><small>POKÉMON POKOPIA</small></div>
          }
        </div>
        <div class="pokopia-info">
          <div class="badges">
            <span class="b hot">Fan guide</span>
            <span class="b">{platforms.join(' / ')}</span>
            <span class="b">Golden path + 100%</span>
            <span class="b">Spoiler-safe</span>
          </div>
          <h1>{title}</h1>
          <p class="lede">{lede}</p>
        </div>
      </div>
      <div class="ctrls">
        <div class="progress-wrap">
          <div class="lab">
            <span>Golden-path progress</span>
            <b id="prog-txt">0 / {sections.length} sections</b>
          </div>
          <div class="bar"><i id="prog-bar"></i></div>
        </div>
        <button class="toggle on" id="spoiler-toggle" onclick="toggleSpoilers()">
          <span class="dot"></span>
          <span id="spoiler-label">Spoiler-safe: ON</span>
        </button>
        <button class="toggle" id="comp-toggle" onclick="toggleComp()">
          <span class="dot"></span>
          <span id="comp-label">Completionist: OFF</span>
        </button>
      </div>
    </div>
  </div>

  <div class="wrap">
    <div class="sections">
      <div class="path-label">Kanto restoration · golden path</div>

      {sections.map((sec: any, i: number) => {
        const sid: string = sec.sectionId ?? String(sec.order);
        const seqEntry = seqBySid.get(sid);
        const gateWarnings: any[] = seqEntry?.gateWarnings ?? [];
        const readinessNote: string | null = seqEntry?.readinessNote ?? null;
        const recommendedDetourIds: string[] = sec.recommendedDetours ?? [];

        return (
          <div class="sec" id={`sec-${i}`}>
            <div class="sec-head" onclick={`toggleSec(${i})`}>
              <div class="num">{i + 1}</div>
              <button
                class="check"
                title="Mark section complete"
                onclick={`event.stopPropagation();markDone(${i})`}
                aria-label={`Mark "${sec.title}" complete`}
              >✓</button>
              <div class="htext">
                <div class="stage">{sec.stage}</div>
                <h2>{sec.title}</h2>
                <div class="chips">
                  {sec.chips.map((c: string) => <span class="chip">{c}</span>)}
                </div>
              </div>
              <div class="chev" aria-hidden="true">▾</div>
            </div>

            <div class="sec-body">
              <div class="inner">
                <div class="sec-content">
                  <div class="prose" id={`prose-${i}`}>
                    <button class="tts" onclick={`speak(${i},event)`} aria-label="Listen to this section">▶ Listen to this section</button>

                    {gateWarnings.filter((w: any) => w.gatingType === 'hard').map((w: any) => (
                      <div class="gate-card gate-hard">
                        <span class="gate-ico" aria-hidden="true">⛔</span>
                        <div class="gate-body">
                          <span class="gate-type">Required to proceed</span>
                          You need <strong>{w.name}</strong> to continue from here.
                        </div>
                      </div>
                    ))}

                    {readinessNote && (
                      <div class="gate-card gate-soft">
                        <span class="gate-ico" aria-hidden="true">👆</span>
                        <div class="gate-body">
                          <span class="gate-type">Recommended first</span>
                          {readinessNote}
                        </div>
                      </div>
                    )}

                    <h3>Golden path</h3>
                    <ol>
                      {sec.steps.map((step: unknown) => (
                        <li>
                          {isStepObj(step) ? (
                            <>
                              <span set:html={step.text} />
                              {step.videoTimestamp !== undefined && (
                                <button
                                  class="ts-btn"
                                  onclick={`seekVid(${i},${step.videoTimestamp})`}
                                  title={`Jump video to ${formatTs(step.videoTimestamp)}`}
                                  aria-label={`Watch from ${formatTs(step.videoTimestamp)}`}
                                >▶ {formatTs(step.videoTimestamp)}</button>
                              )}
                            </>
                          ) : (
                            <Fragment set:html={step as string} />
                          )}
                        </li>
                      ))}
                    </ol>

                    {sec.advisories.filter((a: any) => !a.completionistOnly).map((a: any) => (
                      <div class="adv" data-t={a.type}>
                        <span class="ico" aria-hidden="true">{advIcon[a.type]}</span>
                        <span class="at">{advLabel[a.type]}</span>
                        <span set:html={a.body} />
                      </div>
                    ))}

                    {sec.advisories.filter((a: any) => a.completionistOnly).map((a: any) => (
                      <div class="adv comp-only" data-t={a.type}>
                        <span class="ico" aria-hidden="true">{advIcon[a.type]}</span>
                        <span class="at">{advLabel[a.type]}</span>
                        <span set:html={a.body} />
                      </div>
                    ))}

                    {recommendedDetourIds.length > 0 && (
                      <div class="detour-group">
                        <div class="detour-group-head">Optional · strengthen your habitats</div>
                        {recommendedDetourIds.map((dId: string) => {
                          const d = detourById.get(dId);
                          if (!d) return null;
                          return (
                            <div class={`detour-card detour-${(d as any).type}`}>
                              <div class="detour-head">
                                <span class="opt-badge">Optional</span>
                                <strong class="detour-loc">{(d as any).location}</strong>
                                <span class="detour-benefit">{(d as any).benefit}</span>
                              </div>
                              <p class="detour-method">{(d as any).method}</p>
                            </div>
                          );
                        })}
                      </div>
                    )}

                    {sec.collectibles.length > 0 && (
                      <div class="comp-block comp-only">
                        <h3>Completionist · this area</h3>
                        <div class="cc" id={`cc-${i}`}>0 / {sec.collectibles.length} collected</div>
                        {sec.collectibles.map((c: any, j: number) => (
                          <div class="coll" id={`coll-${i}-${j}`} onclick={`toggleColl(${i},${j})`} role="checkbox" aria-checked="false" tabindex="0">
                            <div class="box" aria-hidden="true">✓</div>
                            <div class="ct">
                              <b>{c.label}</b>
                              <span>{c.note}</span>
                            </div>
                          </div>
                        ))}
                      </div>
                    )}
                  </div>

                  <div class="aside">
                    <h3>Watch it instead</h3>
                    <div class="vid" id={`vid-${i}`} data-id={sec.video.id} data-start={sec.video.startSeconds ?? 0}>
                      <div
                        class="thumb"
                        onclick="playVid(this)"
                        style={`background-image:url(https://i.ytimg.com/vi/${sec.video.id}/hqdefault.jpg)`}
                        role="button"
                        aria-label={`Play: ${sec.video.title}`}
                        tabindex="0"
                      >
                        <span class="dur">{sec.video.durationLabel}</span>
                        <div class="play" aria-hidden="true">
                          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M8 5v14l11-7z"/>
                          </svg>
                        </div>
                      </div>
                      <div class="vmeta">
                        <div class="creator">▶ {sec.video.creator}</div>
                        <div class="vt">{sec.video.title}</div>
                      </div>
                    </div>
                    <p class="lazy-note">▲ thumbnail from YouTube's CDN · the player loads only when you press play</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</Base>

<style>
/* ── Pokopia hero ─────────────────────────────────────────────────────────── */
.pokopia-hero {
  position: relative;
  overflow: hidden;
  padding-bottom: 2.5rem;
  background: linear-gradient(160deg, #0a1a0e 0%, #091510 55%, #040b06 100%);
}

.pokopia-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 80% 60% at 65% -15%, rgba(77,184,122,.15) 0%, transparent 60%),
    radial-gradient(ellipse 50% 50% at 20% 110%, rgba(20,60,20,.3) 0%, transparent 55%);
  pointer-events: none;
}

.pokopia-hero .inner {
  position: relative;
  max-width: 1100px;
  margin: 0 auto;
  padding: 1.5rem 1.5rem 0;
}

.pokopia-top {
  display: flex;
  gap: 2rem;
  align-items: flex-start;
  margin-top: 1.25rem;
}

.pokopia-cover {
  flex-shrink: 0;
  width: 120px;
  height: 155px;
  border-radius: 8px;
  overflow: hidden;
  box-shadow: 0 8px 32px rgba(0,0,0,.7), 0 0 0 1px rgba(77,184,122,.2);
  background: #0a1a0e;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pokopia-cover-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
}

.pokopia-cover-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  color: #4db87a;
  text-align: center;
  padding: 1rem;
}

.pokopia-icon {
  font-size: 2.5rem;
  line-height: 1;
  opacity: .7;
}

.pokopia-cover-placeholder small {
  font-size: .55rem;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: #4a7a50;
}

.pokopia-info {
  flex: 1;
  min-width: 0;
}

.pokopia-info h1 {
  font-size: clamp(1.5rem, 3.5vw, 2.4rem);
  line-height: 1.1;
  margin: 0.5rem 0;
  color: #a8f0c0;
}

.pokopia-info .lede {
  color: #6a9a72;
  font-size: .95rem;
  line-height: 1.6;
  max-width: 56ch;
  margin: 0;
}

@media (max-width: 600px) {
  .pokopia-top {
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .pokopia-cover {
    width: 90px;
    height: 116px;
  }
}
</style>

<script define:vars={{ sectionsJson, totalSections: sections.length }}>
const SECS = JSON.parse(sectionsJson);
const done = new Set();
const collGot = {};

window.toggleSec    = toggleSec;
window.markDone     = markDone;
window.toggleColl   = toggleColl;
window.playVid      = playVid;
window.seekVid      = seekVid;
window.speak        = speak;
window.toggleSpoilers = toggleSpoilers;
window.toggleComp   = toggleComp;

function toggleSec(i) {
  const el = document.getElementById('sec-' + i);
  el.classList.toggle('open');
  el.querySelectorAll('.spoiler').forEach(sp => {
    if (!sp.dataset.bound) {
      sp.dataset.bound = '1';
      sp.addEventListener('click', e => { e.stopPropagation(); sp.classList.add('revealed'); });
    }
  });
}

function markDone(i) {
  const el = document.getElementById('sec-' + i);
  if (done.has(i)) { done.delete(i); el.classList.remove('done'); }
  else { done.add(i); el.classList.add('done'); }
  const n = done.size;
  document.getElementById('prog-txt').textContent = `${n} / ${totalSections} sections`;
  document.getElementById('prog-bar').style.width = (n / totalSections * 100) + '%';
}

function toggleColl(i, j) {
  const el = document.getElementById(`coll-${i}-${j}`);
  el.classList.toggle('got');
  el.setAttribute('aria-checked', String(el.classList.contains('got')));
  collGot[i] = collGot[i] || new Set();
  if (el.classList.contains('got')) collGot[i].add(j); else collGot[i].delete(j);
  document.getElementById('cc-' + i).textContent =
    `${collGot[i].size} / ${SECS[i].collectCount} collected`;
}

document.querySelectorAll('.coll').forEach(el => {
  el.addEventListener('keydown', e => {
    if (e.key === ' ' || e.key === 'Enter') { e.preventDefault(); el.click(); }
  });
});

function playVid(thumb) {
  const card = thumb.closest('.vid'), id = card.dataset.id;
  const start = parseInt(card.dataset.start || '0', 10);
  const f = document.createElement('iframe');
  f.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0${start ? '&start=' + start : ''}`;
  f.allow = 'autoplay; encrypted-media; picture-in-picture; fullscreen';
  f.setAttribute('allowfullscreen', '');
  f.style.cssText = 'width:100%;aspect-ratio:16/9;border:0;display:block;border-radius:14px';
  thumb.replaceWith(f);
}

function seekVid(secIdx, ts) {
  const card = document.getElementById('vid-' + secIdx);
  if (!card) return;
  const id = card.dataset.id;
  const existing = card.querySelector('iframe');
  if (existing) {
    existing.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0&start=${ts}`;
  } else {
    const thumb = card.querySelector('.thumb');
    if (!thumb) return;
    const f = document.createElement('iframe');
    f.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0&start=${ts}`;
    f.allow = 'autoplay; encrypted-media; picture-in-picture; fullscreen';
    f.setAttribute('allowfullscreen', '');
    f.style.cssText = 'width:100%;aspect-ratio:16/9;border:0;display:block;border-radius:14px';
    thumb.replaceWith(f);
  }
}

document.querySelectorAll('.thumb').forEach(el => {
  el.addEventListener('keydown', e => {
    if (e.key === ' ' || e.key === 'Enter') { e.preventDefault(); playVid(el); }
  });
});

let voices = [], speaking = null;
function loadVoices() { voices = speechSynthesis.getVoices(); }
if ('speechSynthesis' in window) { loadVoices(); speechSynthesis.onvoiceschanged = loadVoices; }
function pickVoice() {
  const pref = ['Google UK English Female', 'Google US English', 'Samantha', 'Microsoft Aria', 'Daniel'];
  for (const p of pref) { const v = voices.find(v => v.name.includes(p)); if (v) return v; }
  return voices.find(v => v.lang && v.lang.startsWith('en')) || voices[0];
}
function speak(i, e) {
  e.stopPropagation();
  const btn = e.currentTarget;
  if (!('speechSynthesis' in window)) { return; }
  if (speaking === i) { speechSynthesis.cancel(); speaking = null; resetTTS(); return; }
  speechSynthesis.cancel(); resetTTS();
  const text = document.getElementById('prose-' + i).innerText
    .replace('▶ Listen to this section', '')
    .replace(/\(tap to reveal\)/g, '');
  const u = new SpeechSynthesisUtterance(text);
  const v = pickVoice(); if (v) u.voice = v;
  u.rate = 0.97; u.pitch = 1.02;
  u.onend = () => { speaking = null; resetTTS(); };
  speaking = i;
  btn.classList.add('playing');
  btn.textContent = '■ Stop';
  speechSynthesis.speak(u);
}
function resetTTS() {
  document.querySelectorAll('.tts').forEach(b => {
    b.classList.remove('playing');
    b.textContent = '▶ Listen to this section';
  });
}

function toggleSpoilers() {
  document.body.classList.toggle('spoilers-safe');
  const on = document.body.classList.contains('spoilers-safe');
  document.getElementById('spoiler-toggle').classList.toggle('on', on);
  document.getElementById('spoiler-label').textContent = 'Spoiler-safe: ' + (on ? 'ON' : 'OFF');
}
function toggleComp() {
  document.body.classList.toggle('comp-on');
  const on = document.body.classList.contains('comp-on');
  document.getElementById('comp-toggle').classList.toggle('on', on);
  document.getElementById('comp-label').textContent = 'Completionist: ' + (on ? 'ON' : 'OFF');
}

if (window.location.hash) {
  const m = window.location.hash.match(/^#sec-(\d+)$/);
  if (m) {
    const el = document.getElementById('sec-' + m[1]);
    if (el) {
      toggleSec(Number(m[1]));
      setTimeout(() => el.scrollIntoView({ behavior: 'smooth', block: 'center' }), 120);
    }
  }
}
</script>
