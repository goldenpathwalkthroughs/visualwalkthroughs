---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const franchise = (await getCollection('franchises')).find(f => f.data.slug === 'yoshi');
if (!franchise) throw new Error('Yoshi franchise not found');

const games = (await getCollection('games'))
  .filter(g => g.data.franchiseSlug === 'yoshi')
  .sort((a, b) => b.data.year.localeCompare(a.data.year));

const searchIndex = [
  {
    t: franchise.data.name,
    s: `Franchise · ${franchise.data.guideCount} guide${franchise.data.guideCount === 1 ? '' : 's'}`,
    k: 'franchise',
    ic: '🟢',
    href: '/yoshi/',
  },
  ...games.map(g => ({
    t: g.data.title,
    s: `${g.data.platforms.join(' / ')} · full guide`,
    k: 'game',
    ic: '🟢',
    href: `/yoshi/${g.data.slug}/`,
  })),
];
---

<Base
  title={franchise.data.name}
  description={franchise.data.description}
  bodyClass={franchise.data.theme.bodyClass}
  searchIndex={searchIndex}
>
  <div class="fr-hero">
    <div class="bg" style="background:radial-gradient(120% 90% at 75% -10%,#0a2e03 0%,transparent 55%),linear-gradient(160deg,#051a02,#020800)"></div>
    <div class="inner">
      <div class="crumb">
        <a href="/">Browse</a>
        <span>/</span>
        <span style="color:var(--text)">{franchise.data.name}</span>
      </div>
      <h1>{franchise.data.name}</h1>
      <p>{franchise.data.description}</p>
    </div>
  </div>

  <div class="wrap">
    <div class="game-grid">
      {games.map(g => (
        <a
          href={g.data.status === 'published' ? `/yoshi/${g.data.slug}/` : undefined}
          class={`gtile${g.data.status === 'coming-soon' ? ' soon' : ''}`}
        >
          <div class="art" style={`background:${g.data.theme?.cardGradient ?? g.data.coverGradient}`}>
            {g.data.cover && <img src={g.data.cover} alt={g.data.title} class="cover-img" loading="lazy" decoding="async" />}
          </div>
          {g.data.status === 'published' && <span class="ready">Guide ready</span>}
          <div class="meta">
            <div class="gtitle">{g.data.title}</div>
            <div class="gplat">{g.data.platforms.join(' / ')}</div>
          </div>
        </a>
      ))}
    </div>
  </div>
</Base>

<style>
.fr-hero {
  position: relative;
  overflow: hidden;
  padding-bottom: 2.5rem;
  background: linear-gradient(160deg,#041502 0%,#021000 55%,#020800 100%);
}
.bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
}
.fr-hero .inner {
  position: relative;
  max-width: 1100px;
  margin: 0 auto;
  padding: 1.5rem 1.5rem 0;
}
.fr-hero h1 {
  font-size: clamp(2rem, 5vw, 3.5rem);
  margin: 0.5rem 0;
  color: #b8f090;
}
.fr-hero p {
  color: var(--muted);
  max-width: 60ch;
  font-size: .95rem;
  line-height: 1.65;
}
.crumb {
  display: flex;
  gap: .5rem;
  align-items: center;
  font-size: .78rem;
  color: var(--muted);
}
.crumb a { color: var(--muted); text-decoration: none; }
.crumb a:hover { color: var(--accent); }

.wrap {
  max-width: 1100px;
  margin: 0 auto;
  padding: 2.5rem 1.5rem 4rem;
}
.game-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 1.5rem;
}
.gtile {
  background: var(--panel);
  border-radius: var(--radius);
  overflow: hidden;
  text-decoration: none;
  color: var(--text);
  border: 1px solid var(--line);
  transition: transform .18s, box-shadow .18s, border-color .18s;
  display: flex;
  flex-direction: column;
  position: relative;
}
.gtile:hover {
  transform: translateY(-3px);
  box-shadow: var(--shadow);
  border-color: var(--accent-soft);
}
.gtile.soon { pointer-events: none; opacity: .55; }
.art {
  height: 180px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.cover-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.ready {
  position: absolute;
  top: .75rem;
  right: .75rem;
  background: var(--accent);
  color: #000;
  font-size: .65rem;
  font-weight: 700;
  letter-spacing: .05em;
  text-transform: uppercase;
  border-radius: 4px;
  padding: 2px 7px;
}
.meta {
  padding: 1rem 1.25rem 1.25rem;
}
.gtitle {
  font-weight: 700;
  font-size: .98rem;
  margin-bottom: .25rem;
}
.gplat {
  font-size: .78rem;
  color: var(--muted);
}
</style>
